<!--
  个人中心 - 用户信息、学习数据总览
-->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="profile-header">
    <view class="profile-bg"></view>
    <view class="profile-content">
      <view class="avatar-wrap">
        <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/default-avatar.png'}}" mode="aspectFill" />
      </view>
      <view class="profile-info">
        <text class="profile-name">{{userInfo.nickName || '备考同学'}}</text>
        <text class="profile-bio">坚持打卡 第 {{continuousDays}} 天</text>
      </view>
    </view>
  </view>

  <!-- 学习概览 -->
  <view class="profile-section-head">
    <view class="section-title-group">
      <text class="section-title">学习概览</text>
      <text class="section-subtitle">今日进度、连续打卡与正确率</text>
    </view>
    <text class="section-tag">{{dataSource === 'api' ? '实时数据' : '本地数据'}}</text>
  </view>
  <stats-panel type="overview" stats="{{overviewStats}}" />

  <!-- 学习记录 -->
  <view class="profile-section-head compact">
    <view class="section-title-group">
      <text class="section-title">学习记录</text>
    </view>
  </view>
  <view class="menu-section">
    <view class="menu-item" bindtap="goToCheckinHistory">
      <view class="menu-left">
        <view class="menu-icon">📅</view>
        <text class="menu-text">打卡记录</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">{{continuousDays}} 天连续</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goToWrongBook">
      <view class="menu-left">
        <view class="menu-icon">📊</view>
        <text class="menu-text">错题本</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">{{wrongCount}} 道</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goToQuizHistory">
      <view class="menu-left">
        <view class="menu-icon">🎯</view>
        <text class="menu-text">测试记录</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">{{quizCount}} 次</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="profile-section-head compact">
    <view class="section-title-group">
      <text class="section-title">设置</text>
      <text class="section-subtitle">偏好配置与产品信息</text>
    </view>
  </view>
  <view class="menu-section">
    <view class="menu-item">
      <view class="menu-left">
        <view class="menu-icon">⏱️</view>
        <text class="menu-text">默认倒计时</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">{{defaultDuration}} 分钟</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <view class="menu-icon">🔔</view>
        <text class="menu-text">打卡提醒</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">已开启</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <view class="menu-icon">📖</view>
        <text class="menu-text">关于搞定公考800词</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">v1.0.0 MVP</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom" style="height: 120rpx;"></view>
</view>
