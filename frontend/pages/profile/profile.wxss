/* 个人中心样式 */

/* ===== 用户头部 ===== */
.profile-header {
  position: relative;
  margin: 24rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.profile-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B8AFF 50%, #95A9FF 100%);
}

.profile-content {
  position: relative;
  padding: 48rpx 36rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 1;
}

.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.25);
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.7);
}

.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 36rpx;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 50% 50%;
}

.avatar-edit-text {
  font-size: 18rpx;
  color: rgba(255,255,255,0.85);
}

.profile-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #FFFFFF;
}

.profile-bio {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 分区标题 ===== */
.profile-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin: 34rpx 24rpx 16rpx;
}

.profile-section-head.compact {
  margin-top: 28rpx;
}

.section-title-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.section-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 0;
}

.section-subtitle {
  font-size: 22rpx;
  line-height: 1.35;
  color: var(--color-text-hint);
}

.section-tag {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 600;
}

/* ===== 菜单区域 ===== */
.menu-section {
  margin: 0 24rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  padding: 22rpx 28rpx;
  border-bottom: 2rpx solid var(--color-divider);
  box-sizing: border-box;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F9FAFB;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
  flex: 1;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: var(--radius-md);
  background: #F5F7FA;
  font-size: 28rpx;
}

.menu-text {
  font-size: var(--font-md);
  line-height: 1.35;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.menu-value {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  line-height: 1.35;
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: var(--color-text-hint);
}

/* ===== 会员卡片 ===== */
.member-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 16rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFE082 50%, #FFD54F 100%);
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 20rpx rgba(255, 183, 77, 0.25);
}

.member-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.member-icon {
  font-size: 40rpx;
}

.member-plan {
  font-size: var(--font-md);
  font-weight: 700;
  color: #5D4037;
  display: block;
}

.member-days {
  font-size: var(--font-xs);
  color: #795548;
}

.member-badge {
  background: rgba(255,255,255,0.6);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.member-badge-text {
  font-size: 22rpx;
  color: #F57F17;
  font-weight: 700;
}

/* ===== 激活入口卡片 ===== */
.activate-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 24rpx 16rpx;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 2rpx dashed var(--color-primary);
}

.activate-banner:active {
  transform: scale(0.99);
}

.activate-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.activate-info {
  flex: 1;
}

.activate-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-primary);
  display: block;
}

.activate-desc {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  display: block;
  margin-top: 4rpx;
}

.activate-arrow {
  font-size: 36rpx;
  color: var(--color-primary);
}

/* ===== 激活码弹窗 ===== */
.dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.dialog-card {
  width: 580rpx;
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dialog-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.dialog-desc {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  text-align: center;
  margin-bottom: 36rpx;
}

.dialog-input {
  width: 100%;
  height: 88rpx;
  background: #F5F7FA;
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  font-size: var(--font-lg);
  text-align: center;
  letter-spacing: 4rpx;
  font-weight: 600;
}

.dialog-error {
  font-size: var(--font-xs);
  color: var(--color-danger);
  margin-top: 12rpx;
}

.dialog-btns {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.dialog-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-btn.cancel {
  background: #F5F7FA;
  color: var(--color-text-secondary);
}

.dialog-btn.confirm {
  background: linear-gradient(135deg, #4F6EF7, #6B8AFF);
  color: #FFFFFF;
}

.dialog-btn.confirm[disabled] {
  background: #C7D2FE;
  color: rgba(255,255,255,0.6);
}
