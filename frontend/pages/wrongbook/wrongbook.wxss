/* 错题本页样式 */

/* ===== 非会员锁定页 ===== */
.locked-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 64rpx;
  text-align: center;
}

.locked-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.locked-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.locked-desc {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  line-height: 1.8;
  margin-bottom: 48rpx;
}

.locked-btn {
  width: 400rpx;
}

/* ===== 分类筛选 Tab ===== */
.category-tabs {
  white-space: nowrap;
  padding: 0 24rpx 20rpx;
  display: flex;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  background: var(--color-bg-card);
  border-radius: 40rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.tab-item.active {
  background: var(--color-primary);
}

.tab-name {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.tab-item.active .tab-name {
  color: #FFFFFF;
}

.tab-count {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  background: rgba(0, 0, 0, 0.04);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.tab-item.active .tab-count {
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.15);
}

/* ===== 工具栏 ===== */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 16rpx;
}

.sort-group {
  display: flex;
  gap: 32rpx;
}

.sort-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  padding: 8rpx 0;
}

.sort-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.sort-arrow {
  font-size: var(--font-xs);
}

.toolbar-action {
  padding: 8rpx 24rpx;
}

.action-text {
  font-size: var(--font-xs);
  color: var(--color-primary);
  font-weight: 600;
}

/* ===== 错题列表 ===== */
.wrong-list {
  padding: 0 24rpx;
}

.wrong-item {
  display: flex;
  margin-bottom: 20rpx;
}

.wrong-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 16rpx;
  padding-top: 24rpx;
  flex-shrink: 0;
  width: 56rpx;
}

.marker-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-danger);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.marker-count {
  font-size: 20rpx;
  color: var(--color-danger);
  margin-top: 4rpx;
  font-weight: 600;
}

/* 错题卡片 */
.wrong-card {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  border-left: 6rpx solid var(--color-danger);
  min-width: 0;
}

.wrong-card-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.wrong-word {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.wrong-pinyin {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  background: #F5F5F7;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.category-tag {
  font-size: var(--font-xs);
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.wrong-meaning {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

/* 错误对比 */
.compare-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
}

.compare-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.compare-label {
  font-size: 20rpx;
  color: var(--color-text-hint);
}

.compare-text {
  font-size: var(--font-sm);
  font-weight: 600;
}

.wrong-text {
  color: var(--color-danger);
  text-decoration: line-through;
  text-decoration-color: rgba(255, 59, 48, 0.3);
}

.correct-text {
  color: var(--color-success);
}

.compare-arrow {
  font-size: var(--font-md);
  color: var(--color-text-hint);
  flex-shrink: 0;
}

.wrong-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meta-date {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}

.meta-action {
  font-size: var(--font-xs);
  color: var(--color-primary);
  padding: 4rpx 0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
}
