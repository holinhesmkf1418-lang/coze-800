<!--
  首页 - 搞定公考800词
  ---
  设计重点：突出"搞定公考800词"品牌特色
  - 公考品牌标识 + 公考定位
  - 800词总进度为核心指标
  - 分类掌握度展示学习深度
-->
<view class="page-container">

  <!-- ===== 品牌头部 ===== -->
  <view class="brand-header">
    <view class="brand-row">
      <view class="brand-icon">
        <text class="brand-emoji">🥜</text>
      </view>
      <view class="brand-info">
        <text class="brand-name">搞定公考800词</text>
        <text class="brand-tagline">公考高频成语 · 科学背诵</text>
      </view>
    </view>
    <view class="brand-badge">
      <text class="badge-text">MVP</text>
    </view>
  </view>

  <!-- ===== 800词总进度 Hero 卡片 ===== -->
  <view class="hero-card">
    <view class="hero-top">
      <text class="hero-label">已掌握词汇</text>
      <text class="hero-sub">共 800 个公考高频成语</text>
    </view>
    <view class="hero-progress-big">
      <text class="hero-num-mastered">{{overviewStats.masteredWords}}</text>
      <text class="hero-num-sep">/</text>
      <text class="hero-num-total">800</text>
    </view>
    <view class="hero-bar-wrap">
      <view class="hero-bar-fill" style="width: {{(overviewStats.masteredWords / 800) * 100}}%;"></view>
    </view>
    <view class="hero-percent">{{Math.round((overviewStats.masteredWords / 800) * 100)}}% 掌握率</view>

    <!-- 三指标 -->
    <view class="hero-stats-row">
      <view class="hero-stat">
        <text class="hs-num">{{continuousDays}}</text>
        <text class="hs-label">连续打卡</text>
      </view>
      <view class="hero-stat-div"></view>
      <view class="hero-stat">
        <text class="hs-num text-success">{{overviewStats.accuracy}}%</text>
        <text class="hs-label">正确率</text>
      </view>
      <view class="hero-stat-div"></view>
      <view class="hero-stat">
        <text class="hs-num">{{todayProgress.completed}}/{{todayProgress.total}}</text>
        <text class="hs-label">今日进度</text>
      </view>
    </view>
  </view>

  <!-- ===== 快捷入口 ===== -->
  <view class="section-label">开始学习</view>

  <!-- 打卡 — 主入口，单行突出 -->
  <view class="main-action" bindtap="goToCheckin">
    <view class="main-action-left">
      <view class="main-action-icon">
        <text class="mai-emoji">📝</text>
      </view>
      <view class="main-action-info">
        <text class="mai-title">每日打卡</text>
        <text class="mai-desc">今日 {{todayProgress.completed}}/{{todayProgress.total}} 词 · 逐个学习，确认掌握</text>
      </view>
    </view>
    <view class="main-action-right">
      <text class="mai-badge" wx:if="{{todayProgress.completed < todayProgress.total}}">待完成</text>
      <text class="mai-badge done" wx:else>已完成</text>
      <text class="mai-arrow">›</text>
    </view>
  </view>

  <!-- 测验 + 错题 双列 -->
  <view class="dual-actions">
    <view class="dual-card" bindtap="goToQuiz">
      <view class="dual-icon quiz-bg">
        <text class="dual-emoji">🎯</text>
      </view>
      <text class="dual-title">随心测</text>
      <text class="dual-desc">模拟实战 · 随机100题</text>
    </view>
    <view class="dual-card" bindtap="goToWrongBook">
      <view class="dual-icon wrong-bg">
        <text class="dual-emoji">📊</text>
      </view>
      <text class="dual-title">错题本</text>
      <text class="dual-desc">{{wrongCount}} 道待复习</text>
    </view>
  </view>

  <!-- ===== 分类掌握度 ===== -->
  <view class="section-label">分类掌握</view>
  <view class="category-mastery card">
    <view class="cm-item" wx:for="{{categoryMastery}}" wx:key="category">
      <view class="cm-header">
        <text class="cm-name">{{item.category}}</text>
        <text class="cm-percent {{item.accuracy >= 90 ? 'text-success' : item.accuracy >= 70 ? 'text-warning' : 'text-danger'}}">{{item.accuracy}}%</text>
      </view>
      <view class="cm-bar-track">
        <view class="cm-bar-fill"
          style="width: {{item.accuracy}}%; background: {{item.accuracy >= 90 ? '#34C759' : item.accuracy >= 70 ? '#FF9500' : '#FF3B30'}};">
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 本周打卡 ===== -->
  <view class="section-label">本周打卡</view>
  <view class="week-chart card">
    <view class="week-bars">
      <view class="week-bar-item" wx:for="{{weeklyStats}}" wx:key="day">
        <view class="bar-wrap">
          <view class="bar-fill {{item.count === 0 ? 'bar-empty' : item.count >= 20 ? 'bar-full' : ''}}"
                style="height: {{item.count * 2.8}}rpx;"></view>
        </view>
        <text class="bar-label">{{item.day}}</text>
      </view>
    </view>
  </view>

  <view class="safe-bottom" style="height: 140rpx;"></view>
</view>
