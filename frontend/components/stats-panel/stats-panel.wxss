.stats-panel {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: var(--shadow-sm);
}

/* ===== 通用统计行 ===== */
.stat-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--color-divider);
}

/* 总进度 */
.total-progress {
  padding: 0 8rpx;
}

/* ===== 分类薄弱项 ===== */
.category-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--color-divider);
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-item {
  /* spacing via gap */
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
}

.category-accuracy {
  font-size: var(--font-sm);
  font-weight: 600;
}

.category-count {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  margin-top: 4rpx;
  display: block;
}

/* ===== 成绩圆圈 ===== */
.score-circle-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B8AFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(79, 110, 247, 0.3);
}

.score-number {
  font-size: 72rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.1;
}

.score-unit {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.8);
}
