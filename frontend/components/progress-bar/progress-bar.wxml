<!--
  进度条组件 - ProgressBar
  属性：
    percent: 进度百分比 (0-100)
    showText: 是否显示百分比文字
    color: 进度条颜色（默认主题色）
    height: 进度条高度（默认 12rpx）
    label: 左侧标签文字
-->
<view class="progress-wrapper">
  <view class="progress-label" wx:if="{{label}}">{{label}}</view>
  <view class="progress-track" style="height: {{height}}rpx;">
    <view
      class="progress-fill"
      style="width: {{percent}}%; background: {{color || '#4F6EF7'}}; height: {{height}}rpx;"
    ></view>
  </view>
  <text class="progress-text" wx:if="{{showText}}">{{percent}}%</text>
</view>
