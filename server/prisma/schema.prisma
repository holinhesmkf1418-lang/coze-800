// ============================================================
// 搞定800词 · 数据库 Schema
// 微信小程序：公考花生800词背诵工具
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------- 词汇表 ----------
// 存储800个成语/词汇，支持分类，预留例句字段
model Vocabulary {
  id         Int       @id @default(autoincrement())
  word       String    @db.VarChar(50)       // 词条（成语）
  definition String    @db.Text               // 释义
  category   String?   @db.VarChar(50)       // 分类（如：政治、经济、文化...）
  seqNo      Int?                             // 序号（原始排序）
  example    String?   @db.Text               // 例句
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // 关联
  wrongAnswers  WrongAnswerRecord[]
  testAnswers   TestAnswer[]
  dailyVocabs   DailyVocab[]

  @@index([category])
  @@index([seqNo])
  @@map("vocabularies")
}

// ---------- 用户表 ----------
// 微信登录用户，openid 唯一标识
model User {
  id          Int       @id @default(autoincrement())
  openid      String    @unique @db.VarChar(64)  // 微信 openid
  unionId     String?   @db.VarChar(64)           // 微信 unionid（可选）
  nickname    String?   @db.VarChar(64)           // 微信昵称
  avatarUrl   String?   @db.VarChar(512)          // 头像URL
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime  @updatedAt

  // 关联
  checkInRecords  CheckInRecord[]
  wrongAnswers    WrongAnswerRecord[]
  testRecords     TestRecord[]

  @@map("users")
}

// ---------- 每日打卡词汇配置表 ----------
// 每日推送哪些词汇（可预配置，如每日10词）
model DailyVocab {
  id       Int        @id @default(autoincrement())
  date     DateTime   @db.Date                    // 打卡日期
  vocabId  Int                                    // 词汇ID
  sortNo   Int        @default(0)                 // 当日排序

  vocab    Vocabulary @relation(fields: [vocabId], references: [id])

  @@unique([date, vocabId])
  @@index([date])
  @@map("daily_vocabs")
}

// ---------- 打卡记录表 ----------
// 用户每日打卡状态
model CheckInRecord {
  id         Int       @id @default(autoincrement())
  userId     Int
  date       DateTime  @db.Date                   // 打卡日期
  completed  Boolean   @default(false)             // 是否完成当日全部
  vocabCount Int       @default(0)                // 当日已学词汇数
  totalCount Int       @default(10)               // 当日总词汇数
  checkedAt  DateTime?                            // 完成打卡时间

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("check_in_records")
}

// ---------- 错题记录表 ----------
// 收录用户做错的每一题，支持来源分类（每日打卡/随心测）
model WrongAnswerRecord {
  id         Int       @id @default(autoincrement())
  userId     Int
  vocabId    Int
  sourceType SourceType @default(DAILY)           // DAILY=每日打卡, SPRINT=随心测
  wrongCount Int       @default(1)                // 累计错误次数（同一用户同一词可重复错）
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User       @relation(fields: [userId], references: [id])
  vocab Vocabulary @relation(fields: [vocabId], references: [id])

  @@unique([userId, vocabId])
  @@index([userId])
  @@index([vocabId])
  @@index([sourceType])
  @@map("wrong_answer_records")
}

enum SourceType {
  DAILY
  SPRINT
}

// ---------- 测试记录表 ----------
// 随心测的完整记录
model TestRecord {
  id         Int       @id @default(autoincrement())
  userId     Int
  score      Int                                  // 得分（正确数）
  total      Int       @default(100)              // 总题数
  timeLimit  Int       @default(0)                // 倒计时秒数（0=不限时）
  duration   Int       @default(0)                // 实际用时秒数
  status     TestStatus @default(IN_PROGRESS)     // IN_PROGRESS / COMPLETED / TIMEOUT
  autoSubmit Boolean   @default(false)            // 是否超时自动交卷
  createdAt  DateTime  @default(now())

  user    User          @relation(fields: [userId], references: [id])
  answers TestAnswer[]

  @@index([userId])
  @@index([createdAt])
  @@map("test_records")
}

enum TestStatus {
  IN_PROGRESS
  COMPLETED
  TIMEOUT
}

// ---------- 测试答题明细表 ----------
// 每题的用户答案和判分
model TestAnswer {
  id             Int     @id @default(autoincrement())
  testRecordId   Int
  vocabId        Int
  sortNo         Int     @default(0)                // 题号
  selectedOption String? @db.VarChar(1)             // 用户选择的选项 label (A/B/C/D)
  correctOption  String  @default("A") @db.VarChar(1) // 正确答案 label
  isCorrect      Boolean @default(false)            // 是否答对

  testRecord TestRecord @relation(fields: [testRecordId], references: [id])
  vocab      Vocabulary @relation(fields: [vocabId], references: [id])

  @@index([testRecordId])
  @@map("test_answers")
}

// ---------- 词汇导入批次表 ----------
// 记录800词导入历史
model ImportBatch {
  id         Int       @id @default(autoincrement())
  fileName   String    @db.VarChar(255)           // 导入文件名
  format     String    @db.VarChar(10)            // CSV / JSON
  totalCount Int                                  // 总条数
  successCount Int                                // 成功导入数
  failCount   Int       @default(0)               // 失败数
  importedAt DateTime  @default(now())

  @@map("import_batches")
}
