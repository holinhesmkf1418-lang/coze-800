// ============================================================
// 搞定800词 · 数据库 Schema
// 微信小程序：公考花生800词背诵工具
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------- 词汇表 ----------
model Vocabulary {
  id         Int       @id @default(autoincrement())
  word       String    @db.VarChar(50)
  definition String    @db.Text
  category   String?   @db.VarChar(50)
  seqNo      Int?      @map("seq_no")
  example    String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  wrongAnswers  WrongAnswerRecord[]
  testAnswers   TestAnswer[]
  dailyVocabs   DailyVocab[]

  @@index([category])
  @@index([seqNo])
  @@map("vocabularies")
}

// ---------- 用户表 ----------
model User {
  id          Int       @id @default(autoincrement())
  openid      String    @unique @db.VarChar(64)
  unionId     String?   @map("union_id") @db.VarChar(64)
  nickname    String?   @db.VarChar(64)
  avatarUrl   String?   @map("avatar_url") @db.VarChar(512)
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime  @updatedAt @map("last_login_at")

  checkInRecords  CheckInRecord[]
  wrongAnswers    WrongAnswerRecord[]
  testRecords     TestRecord[]

  @@map("users")
}

// ---------- 每日打卡词汇配置表 ----------
model DailyVocab {
  id       Int        @id @default(autoincrement())
  date     DateTime   @db.Date
  vocabId  Int        @map("vocab_id")
  sortNo   Int        @default(0) @map("sort_no")

  vocab    Vocabulary @relation(fields: [vocabId], references: [id])

  @@unique([date, vocabId])
  @@index([date])
  @@map("daily_vocabs")
}

// ---------- 打卡记录表 ----------
model CheckInRecord {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  date       DateTime  @db.Date
  completed  Boolean   @default(false)
  vocabCount Int       @default(0) @map("vocab_count")
  totalCount Int       @default(10) @map("total_count")
  checkedAt  DateTime? @map("checked_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("check_in_records")
}

// ---------- 错题记录表 ----------
model WrongAnswerRecord {
  id         Int        @id @default(autoincrement())
  userId     Int        @map("user_id")
  vocabId    Int        @map("vocab_id")
  sourceType SourceType @default(DAILY) @map("source_type")
  wrongCount Int        @default(1) @map("wrong_count")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  user User       @relation(fields: [userId], references: [id])
  vocab Vocabulary @relation(fields: [vocabId], references: [id])

  @@unique([userId, vocabId])
  @@index([userId])
  @@index([vocabId])
  @@index([sourceType])
  @@map("wrong_answer_records")
}

enum SourceType {
  DAILY
  SPRINT
}

// ---------- 测试记录表 ----------
model TestRecord {
  id         Int        @id @default(autoincrement())
  userId     Int        @map("user_id")
  score      Int
  total      Int        @default(100)
  timeLimit  Int        @default(0) @map("time_limit")
  duration   Int        @default(0)
  status     TestStatus @default(IN_PROGRESS)
  autoSubmit Boolean    @default(false) @map("auto_submit")
  createdAt  DateTime   @default(now()) @map("created_at")

  user    User          @relation(fields: [userId], references: [id])
  answers TestAnswer[]

  @@index([userId])
  @@index([createdAt])
  @@map("test_records")
}

enum TestStatus {
  IN_PROGRESS
  COMPLETED
  TIMEOUT
}

// ---------- 测试答题明细表 ----------
model TestAnswer {
  id             Int      @id @default(autoincrement())
  testRecordId   Int      @map("test_record_id")
  vocabId        Int      @map("vocab_id")
  sortNo         Int      @default(0) @map("sort_no")
  selectedOption String?  @map("selected_option") @db.VarChar(1)
  correctOption  String   @default("A") @map("correct_option") @db.VarChar(1)
  isCorrect      Boolean  @default(false) @map("is_correct")

  testRecord TestRecord @relation(fields: [testRecordId], references: [id])
  vocab      Vocabulary @relation(fields: [vocabId], references: [id])

  @@index([testRecordId])
  @@map("test_answers")
}

// ---------- 词汇导入批次表 ----------
model ImportBatch {
  id           Int      @id @default(autoincrement())
  fileName     String   @map("file_name") @db.VarChar(255)
  format       String   @map("format") @db.VarChar(10)
  totalCount   Int      @map("total_count")
  successCount Int      @map("success_count")
  failCount    Int      @default(0) @map("fail_count")
  importedAt   DateTime @default(now()) @map("imported_at")

  @@map("import_batches")
}

// ---------- 激活码表 ----------
model ActivationCode {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(50)
  planType     String    @default("SPRINT_30") @map("plan_type") @db.VarChar(30)
  durationDays Int       @default(30) @map("duration_days")
  maxUses      Int       @default(1) @map("max_uses")
  usedCount    Int       @default(0) @map("used_count")
  startsAt     DateTime? @map("starts_at")
  expiresAt    DateTime? @map("expires_at")
  status       String    @default("ACTIVE") @db.VarChar(20)
  note         String?   @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  redemptions ActivationRedemption[]

  @@index([status])
  @@map("activation_codes")
}

// ---------- 激活码兑换记录表 ----------
model ActivationRedemption {
  id         Int      @id @default(autoincrement())
  codeId     Int      @map("code_id")
  userId     Int      @map("user_id")
  redeemedAt DateTime @default(now()) @map("redeemed_at")

  code ActivationCode @relation(fields: [codeId], references: [id])

  @@unique([codeId, userId])
  @@index([userId])
  @@map("activation_redemptions")
}

// ---------- 用户会员表 ----------
model UserMembership {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  planType     String   @default("SPRINT_30") @map("plan_type") @db.VarChar(30)
  startsAt     DateTime @default(now()) @map("starts_at")
  expiresAt    DateTime @map("expires_at")
  source       String   @default("ACTIVATION_CODE") @db.VarChar(30)
  sourceCodeId Int?     @map("source_code_id")
  status       String   @default("ACTIVE") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("user_memberships")
}
