# ============================================================
# 搞定公考800词 · 环境变量
# 复制为 .env 后修改
# ============================================================

# ---- 通用 ----
NODE_ENV=development       # development=启用dev-login | production=禁用dev-login
PORT=3000

# ---- 数据库 (MySQL 8.0) ----
# 本地开发: mysql://root:password@localhost:3306/gongkao_800_words
# Docker:    mysql://root:password@mysql:3306/gongkao_800_words
DATABASE_URL="mysql://root:password@localhost:3306/gongkao_800_words"

# ---- 微信小程序 (上线必填) ----
# 从 https://mp.weixin.qq.com → 开发管理 → 开发设置 获取
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret

# ---- JWT ----
# 生产环境务必修改为随机长字符串 (openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ---- 导入 ----
# 最大上传文件大小 (字节, 默认10MB)
IMPORT_MAX_FILE_SIZE=10485760
